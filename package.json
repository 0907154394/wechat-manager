{
  "name": "wechat-manager",
  "version": "1.2.6",
  "main": "electron-main.js",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "build": "electron-builder --win",
    "release": "electron-builder --win --publish=always && node scripts/publish-release.js"
  },
  "type": "commonjs",
  "dependencies": {
    "cors": "^2.8.5",
    "electron-updater": "^6.8.3",
    "express": "^4.21.2",
    "imapflow": "^1.0.181",
    "mongoose": "^8.12.1",
    "multer": "^2.1.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "electron": "^33.3.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.wechatmanager.app",
    "productName": "WeChat Manager",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      ".env",
      "!dist/**",
      "!.git/**",
      "!.gitignore",
      "!*.bat",
      "!*.jsonl",
      "!cloudflare-url.txt"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "0907154394",
      "repo": "wechat-manager",
      "private": true
    }
  }
}
